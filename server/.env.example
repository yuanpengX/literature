DATABASE_URL=sqlite:///./literature.db
# arXiv 查询语法，参见 https://arxiv.org/help/api/user-manual
ARXIV_QUERY=cat:q-bio.* OR cat:cs.LG
ARXIV_MAX_RESULTS=30
# 逗号分隔 RSS URL，可选
RSS_FEEDS=
PAPER_TTL_DAYS=60
EVENT_TTL_DAYS=30
RECOMMEND_ALPHA_HOT=0.45
RECOMMEND_BETA_INTEREST=0.45
RECOMMEND_GAMMA_RECENCY=0.10
# Feed：订阅预筛；无启用订阅且为 true 时列表为空
FEED_STRICT_SUBSCRIPTION_FILTER=false
FEED_MERGE_MAX_TOTAL=900
FEED_MERGE_PER_CHANNEL=350
FEED_FRESH_DAYS=7
FEED_TRENDING_HOT_NORM_MIN=0.55

# 每日精选（用户自愿同步 LLM 到 user_profiles 后，由定时任务调用其 Key）
DAILY_PICKS_HOUR=6
DAILY_PICKS_MINUTE=30
DAILY_PICKS_TIMEZONE=Asia/Shanghai
DAILY_PICKS_MAX_CANDIDATES=48
DAILY_PICKS_ABSTRACT_CHARS=600

# 全库抓取间隔（小时），含 arXiv、RSS、用户订阅期刊、OpenAlex（含会议类型批量）
INGEST_INTERVAL_HOURS=1
# OpenAlex（期刊/会议数据依赖此项；需能访问 api.openalex.org）
OPENALEX_ENABLED=false
# 在 https://openalex.org/settings/api 获取；建议开启 OpenAlex 时填写
OPENALEX_API_KEY=
OPENALEX_MAILTO=mailto:you@example.com
OPENALEX_FETCH_CONFERENCE_WORKS=true
OPENALEX_SUBSCRIPTION_PER_SOURCE=35

# 微信小程序登录（code2Session + JWT）；不配则 /auth/wechat/login 不可用
WECHAT_MINIPROGRAM_APP_ID=
WECHAT_MINIPROGRAM_APP_SECRET=
# 用于签发 access_token，请使用长随机串（勿与 app secret 相同）
JWT_SECRET=
JWT_EXPIRES_DAYS=30
