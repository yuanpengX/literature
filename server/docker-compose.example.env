# 复制为 server/.env 后由根目录 docker-compose 自动加载（可选）
# cp server/docker-compose.example.env server/.env

ARXIV_QUERY=cat:q-bio.* OR cat:cs.LG
ARXIV_MAX_RESULTS=30
RSS_FEEDS=
PAPER_TTL_DAYS=60
EVENT_TTL_DAYS=30

# OpenAlex（可选，需网络可达 api.openalex.org）
OPENALEX_ENABLED=false
OPENALEX_MAILTO=mailto:you@example.com
OPENALEX_PER_PAGE=25
OPENALEX_LOOKBACK_DAYS=120
# 例如只拉某会议：填该来源在 OpenAlex 的 Source ID（S 开头）
OPENALEX_VENUE_SOURCE_ID=
OPENALEX_FILTER_EXTRA=
OPENALEX_ENRICH_ARXIV_CITATIONS=true
OPENALEX_ENRICH_PER_RUN=20
OPENALEX_ENRICH_POOL=120
