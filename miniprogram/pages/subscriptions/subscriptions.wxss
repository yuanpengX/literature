.page-root {
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  background: #F7F2FA;
}

.main-scroll {
  flex: 1;
  height: 0;
  min-height: 0;
  box-sizing: border-box;
}

.scroll-inner {
  padding: 24rpx;
  padding-bottom: 32rpx;
  box-sizing: border-box;
}

.intro {
  display: block;
  font-size: 24rpx;
  color: #49454F;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.err {
  color: #B3261E;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  background: #F3EDF7;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #49454F;
}

.tab.on {
  background: #E8DEF8;
  color: #3D5AFE;
  font-weight: 600;
}

.panel {
  margin-bottom: 8rpx;
}

.row-btns {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.mini {
  background: #E8DEF8;
  color: #381E72;
}

.row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #E7E0EC;
  gap: 16rpx;
}

.col {
  flex: 1;
  min-width: 0;
}

.t {
  display: block;
  font-size: 28rpx;
  color: #1C1B1F;
}

.s {
  display: block;
  font-size: 22rpx;
  color: #49454F;
  word-break: break-all;
}

.del {
  font-size: 24rpx;
  color: #B3261E;
  padding: 8rpx;
}

.kw-add {
  display: flex;
  gap: 12rpx;
  align-items: center;
  margin-bottom: 16rpx;
}

.kw-add .input {
  flex: 1;
  border: 2rpx solid #CAC4D0;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
}

.footer {
  flex-shrink: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #FFFBFE;
  border-top: 1rpx solid #E7E0EC;
  box-sizing: border-box;
}

.btn {
  background: #3D5AFE;
  color: #fff;
  border-radius: 24rpx;
  margin-top: 12rpx;
}

.btn-light {
  background: #E8DEF8;
  color: #381E72;
  border-radius: 24rpx;
}

.hint {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6750A4;
}

.mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal {
  width: 86%;
  background: #FFFBFE;
  border-radius: 24rpx;
  padding: 32rpx;
}

.mt {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.modal .input {
  border: 2rpx solid #CAC4D0;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.modal-btns {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 16rpx;
}
