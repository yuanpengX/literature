<view class="page">
  <view wx:if="{{loading && items.length === 0}}" class="center"><text>加载中…</text></view>
  <view wx:elif="{{error}}" class="center"><text>{{error}}</text></view>
  <view wx:else>
    <view class="meta" wx:if="{{pickDate}}">
      <text class="date">{{pickDate}}</text>
      <text wx:if="{{note}}" class="note">{{note}}</text>
      <text wx:if="{{!serverLlm}}" class="warn">服务端未配置 LLM，精选可能为空或报错。</text>
    </view>
    <view class="actions">
      <button class="btn-run" size="mini" bindtap="runNow" loading="{{runLoading}}">立即生成</button>
    </view>
    <view wx:if="{{items.length === 0}}" class="empty">今日暂无精选条目</view>
    <view class="list" wx:else>
      <paper-card
        wx:for="{{items}}"
        wx:key="id"
        paper="{{item}}"
        position="{{index}}"
        bind:open="onOpenPaper"
      />
    </view>
  </view>
</view>
