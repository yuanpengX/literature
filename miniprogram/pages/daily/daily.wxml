<view class="page">
  <view wx:if="{{loading && items.length === 0}}" class="center"><text>加载中…</text></view>
  <view wx:elif="{{error}}" class="center"><text>{{error}}</text></view>
  <view wx:else>
    <view class="meta" wx:if="{{pickDate}}">
      <text class="date">{{pickDate}}</text>
      <text wx:if="{{note}}" class="note">{{note}}</text>
      <text wx:if="{{!serverLlm}}" class="warn">服务端未配置 LLM，精选可能为空或报错。</text>
      <view wx:if="{{subscriptionKeywords.length}}" class="kw-block">
        <text class="kw-title">已启用订阅关键词（与「设置 → 订阅配置」一致）</text>
        <view class="kw-tags">
          <text wx:for="{{subscriptionKeywords}}" wx:for-index="idx" wx:key="idx" class="kw-tag">{{item}}</text>
        </view>
      </view>
      <text wx:elif="{{serverLlm}}" class="kw-hint">当前未启用订阅关键词；精选将不按关键词预筛。可在订阅配置中添加。</text>
    </view>
    <view class="actions">
      <button class="btn-run" size="mini" bindtap="runNow" loading="{{runLoading}}">立即生成</button>
    </view>
    <view wx:if="{{items.length === 0}}" class="empty">今日暂无精选条目</view>
    <view class="list" wx:else>
      <paper-card
        wx:for="{{items}}"
        wx:for-item="row"
        wx:key="paper.id"
        paper="{{row.paper}}"
        pick-blurb="{{row.pick_blurb}}"
        position="{{index}}"
        bind:open="onOpenPaper"
      />
    </view>
  </view>
</view>
