.page {
  min-height: 100vh;
  padding: 24rpx;
}

.center,
.empty {
  padding: 80rpx 32rpx;
  text-align: center;
  color: #49454F;
}

.meta {
  margin-bottom: 24rpx;
}

.date {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1C1B1F;
}

.note {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #49454F;
}

.warn {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #B3261E;
}

.kw-block {
  margin-top: 16rpx;
}

.kw-title {
  display: block;
  font-size: 24rpx;
  color: #49454F;
  margin-bottom: 12rpx;
}

.kw-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.kw-tag {
  font-size: 22rpx;
  color: #381E72;
  background: #E8DEF8;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
}

.kw-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #49454F;
  line-height: 1.5;
}

.actions {
  margin-bottom: 24rpx;
}

.btn-run {
  background: #3D5AFE;
  color: #fff;
}

.list {
  padding-bottom: 48rpx;
}
