<view class="page">
  <view class="tabs">
    <view
      class="tab {{channel === 'arxiv' ? 'tab-on' : ''}}"
      data-ch="arxiv"
      bindtap="onChannel"
    >arXiv</view>
    <view
      class="tab {{channel === 'journal' ? 'tab-on' : ''}}"
      data-ch="journal"
      bindtap="onChannel"
    >期刊</view>
    <view
      class="tab {{channel === 'conference' ? 'tab-on' : ''}}"
      data-ch="conference"
      bindtap="onChannel"
    >会议</view>
  </view>

  <view class="tabs tabs-sort">
    <view
      class="tab {{sort === 'recommended' ? 'tab-on' : ''}}"
      data-sort="recommended"
      bindtap="onSort"
    >综合</view>
    <view
      class="tab {{sort === 'hot' ? 'tab-on' : ''}}"
      data-sort="hot"
      bindtap="onSort"
    >热门</view>
  </view>

  <view wx:if="{{loading && items.length === 0}}" class="center">
    <text>加载中…</text>
  </view>
  <view wx:elif="{{error && items.length === 0}}" class="center">
    <text>{{error}}</text>
  </view>
  <view wx:elif="{{!loading && items.length === 0}}" class="empty">
    <text class="empty-title">暂无推荐</text>
    <text class="empty-desc">下拉可请求服务端抓取并刷新列表。</text>
  </view>

  <view wx:else class="list-wrap">
    <paper-card
      wx:for="{{items}}"
      wx:key="id"
      paper="{{item}}"
      position="{{index}}"
      bind:open="onOpenPaper"
    />
    <button
      wx:if="{{nextCursor}}"
      class="more-btn"
      loading="{{loadingMore}}"
      bindtap="loadMore"
    >加载更多</button>
  </view>
</view>
