.page {
  min-height: 100vh;
  padding-bottom: 24rpx;
  position: relative;
}

.fab-top {
  position: fixed;
  right: 28rpx;
  bottom: calc(160rpx + env(safe-area-inset-bottom));
  z-index: 500;
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  background: #6750a4;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.18);
}

.fab-top-hover {
  opacity: 0.88;
}

/* 页面滚动时频道/排序栏吸顶 */
.tab-bar-sticky {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #fffbfe;
}

.tabs {
  display: flex;
  background: #FFFBFE;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid #E7E0EC;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #49454F;
  background: #F3EDF7;
}

.tab-on {
  background: #E8DEF8;
  color: #3D5AFE;
  font-weight: 600;
}

.tabs-sort {
  border-bottom: none;
  padding-top: 0;
}

.feed-incomplete-hint {
  font-size: 26rpx;
  line-height: 1.5;
  color: #3d5afe;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.list-wrap {
  padding: 24rpx;
}

.center,
.empty {
  padding: 120rpx 48rpx;
  text-align: center;
  color: #49454F;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #1C1B1F;
}

.empty-desc {
  font-size: 26rpx;
  line-height: 1.6;
}

.empty-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: #49454F;
}

.more-btn {
  margin: 16rpx 0 48rpx;
  background: #3D5AFE;
  color: #fff;
  border-radius: 24rpx;
}
