.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F7F2FA;
}

.scroll {
  flex: 1;
  height: 0;
}

.inner {
  padding: 32rpx;
  padding-bottom: 120rpx;
}

.fav-row {
  margin-bottom: 16rpx;
}

.fav-btn {
  background: #E8DEF8;
  color: #3D5AFE;
  border-radius: 20rpx;
}

.center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #49454F;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1C1B1F;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.sub {
  display: block;
  font-size: 22rpx;
  color: #49454F;
  margin-bottom: 8rpx;
}

.cite {
  display: block;
  font-size: 24rpx;
  color: #49454F;
  margin-bottom: 24rpx;
}

.sec-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  margin: 32rpx 0 12rpx;
}

.body {
  display: block;
  font-size: 28rpx;
  line-height: 1.55;
  color: #1C1B1F;
}

.hint {
  display: block;
  font-size: 24rpx;
  color: #49454F;
  margin-bottom: 16rpx;
}

.err {
  display: block;
  color: #B3261E;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.btn-outline {
  margin: 16rpx 0;
  border: 2rpx solid #6750A4;
  color: #6750A4;
  background: transparent;
  border-radius: 24rpx;
}

.btn-main {
  margin-top: 16rpx;
  background: #3D5AFE;
  color: #fff;
  border-radius: 24rpx;
}
