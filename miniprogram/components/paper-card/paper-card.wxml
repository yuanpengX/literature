<view class="card" bindtap="onTap">
  <view class="row-tags">
    <block wx:for="{{tagChips}}" wx:key="text">
      <text class="tag {{item.cls}}">{{item.text}}</text>
    </block>
    <text class="tag tag-muted">{{paper.source}}</text>
    <text wx:if="{{paper.citation_count > 0}}" class="tag tag-muted">引用 {{paper.citation_count}}</text>
  </view>
  <text class="title">{{paper.title}}</text>
  <text wx:if="{{paper.authors_text}}" class="authors">{{paper.authors_text}}</text>
  <view class="stars-row">
    <text class="stars-label">阅读价值</text>
    <text class="stars-core"><text class="star-on">{{starsFilled}}</text><text class="star-off">{{starsEmpty}}</text></text>
  </view>
  <view wx:if="{{summaryLine}}" class="pick-blurb">{{summaryLine}}</view>
</view>
