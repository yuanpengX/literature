.card {
  background-color: #F7F2FA;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(61, 90, 254, 0.08), 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.row-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tag {
  font-size: 22rpx;
}

.tag-reason,
.tag-hot {
  color: #3D5AFE;
  font-weight: 500;
}

.tag-new {
  color: #7D5260;
  font-weight: 600;
}

.tag-muted {
  color: #49454F;
}

.authors {
  display: block;
  font-size: 24rpx;
  color: #49454F;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stars-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.stars-label {
  font-size: 24rpx;
  color: #49454F;
}

.stars-core {
  font-size: 30rpx;
  letter-spacing: 4rpx;
}

.star-on {
  color: #3D5AFE;
}

.star-off {
  color: #CAC4D0;
}

.pick-blurb {
  display: block;
  font-size: 28rpx;
  color: #381E72;
  background: rgba(61, 90, 254, 0.12);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 0;
  line-height: 1.55;
  white-space: pre-wrap;
}

.title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1B1F;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

