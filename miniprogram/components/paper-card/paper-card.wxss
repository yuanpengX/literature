.card {
  background-color: #F7F2FA;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
}

.row-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tag {
  font-size: 22rpx;
}

.tag-reason {
  color: #3D5AFE;
  font-weight: 500;
}

.tag-muted {
  color: #49454F;
}

.title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1B1F;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.abstract {
  display: block;
  font-size: 26rpx;
  color: #49454F;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  line-height: 1.45;
}
