/** 对齐 Android Material3 浅色主题主色 */
page {
  background-color: #F7F2FA;
  color: #1C1B1F;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.m3-surface {
  background-color: #F3EDF7;
  border-radius: 16rpx;
}

.m3-primary {
  color: #3D5AFE;
}

.m3-muted {
  color: #49454F;
  font-size: 24rpx;
}

.m3-title {
  font-size: 34rpx;
  font-weight: 600;
}

.m3-card {
  background-color: #F7F2FA;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
}

.btn-primary {
  background-color: #3D5AFE !important;
  color: #fff !important;
  border-radius: 24rpx !important;
}
