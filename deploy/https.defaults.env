# Caddy 容器环境变量（提交仓库；可被 deploy/https.env 覆盖）
# 证书：宿主机目录由 deploy/compose.https.env 的 CERT_HOST_DIR 挂载到容器内 /etc/caddy/certs

LITERATURE_DOMAIN=cppteam.cn
CADDY_TLS_CERT=/etc/caddy/certs/fullchain.pem
CADDY_TLS_KEY=/etc/caddy/certs/privkey.pem

# 若阿里云一键部署使用 /ssl/cert.pem、/ssl/cert.key，请：
# 1) deploy/compose.https.env 中设 CERT_HOST_DIR=/ssl
# 2) deploy/https.env 中设 CADDY_TLS_CERT=/etc/caddy/certs/cert.pem 与 CADDY_TLS_KEY=/etc/caddy/certs/cert.key
